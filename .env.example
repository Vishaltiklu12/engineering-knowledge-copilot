APP_NAME=engineering-knowledge-copilot
ENVIRONMENT=local
LOG_LEVEL=INFO
API_V1_PREFIX=/v1
AUTO_CREATE_SCHEMA=true
REQUIRE_DATABASE_ON_STARTUP=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=knowledge_copilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/knowledge_copilot

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.pdf,.docx
ALLOWED_UPLOAD_MIME_TYPES=text/plain,text/markdown,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
CHUNKING_STRATEGY=sliding_window
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=40
EMBEDDING_PROVIDER=placeholder
EMBEDDING_DIMENSIONS=256
EMBEDDING_MODEL=local-deterministic-v1
LLM_PROVIDER=placeholder
LLM_MODEL=extractive-rag-v1
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=500
GROUNDED_ANSWER_MIN_CONFIDENCE=0.45
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
MODEL_REQUEST_TIMEOUT_SECONDS=45
MODEL_RETRY_ATTEMPTS=3
MODEL_RETRY_DELAY_SECONDS=0.5
MODEL_RETRY_BACKOFF_MULTIPLIER=2.0
QUERY_CACHE_TTL_SECONDS=300
DEFAULT_TOP_K=5
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
UPLOAD_RATE_LIMIT_PER_MINUTE=10
QUERY_RATE_LIMIT_PER_MINUTE=60
RETRIEVAL_RATE_LIMIT_PER_MINUTE=90
CONTACT_RATE_LIMIT_PER_MINUTE=12
ENQUEUE_RETRY_ATTEMPTS=3
ENQUEUE_RETRY_DELAY_SECONDS=0.25
ENQUEUE_RETRY_BACKOFF_MULTIPLIER=2.0
INGESTION_TASK_MAX_RETRIES=5
INGESTION_TASK_RETRY_BACKOFF_SECONDS=5
CONTACT_OWNER_NAME=Yasaswini Adivanne
CONTACT_RECEIVER_EMAIL=adivanne.yasaswini@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Yasaswini Portfolio
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
